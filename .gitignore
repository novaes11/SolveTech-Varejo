# ─── Projeto (arquivos gerados em runtime) ────────────────────
backend/solvetech.db
backend/solvetech.db-journal
backend/uploads/

# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.Python
venv/
.venv/
env/
ENV/

# ─── Testes / Coverage (Python) ──────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
coverage.xml
nosetests.xml
*.cover
*.py.cover

# ─── Node.js / Frontend ──────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt

# ─── Variáveis de ambiente ────────────────────────────────────
.env
.env.local
.env.*.local

# ─── IDEs e Editores ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
tempCodeRunnerFile.py

# ─── Type checkers / Linters ─────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/
